{
  "name": "raven-ts",
  "version": "0.1.0",
  "description": "Feishu/Lark control service for Claude and Codex Agent SDKs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "raven-ts": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "scripts",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "postinstall": "node scripts/patch-codex-sdk.js && node scripts/install-raven-skills.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-agent-sdk",
    "codex",
    "codex-agent-sdk",
    "feishu",
    "lark",
    "chatbot"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.123",
    "@larksuiteoapi/node-sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.128.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.1",
    "ora": "^7.0.1",
    "uuid": "^9.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3"
  }
}
